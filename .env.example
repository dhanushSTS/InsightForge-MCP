# ============================================================
# InsightForge MCP — Environment Configuration (template)
# Copy this file to `.env` and fill in real values.
#   cp .env.example .env
# ============================================================

# ---- PostgreSQL connection ----
# Full connection string (preferred). Format:
#   postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/insightforge

# ---- Query safety guardrails ----
# Hard cap on rows any single query/tool may return to the LLM.
MAX_QUERY_ROWS=1000

# Statement timeout for read queries, in milliseconds.
QUERY_TIMEOUT_MS=10000

# ---- Output artifacts ----
# Directory (relative to the backend/ folder) where CSV files and
# generated charts are written.
EXPORT_DIR=exports

# ---- Logging ----
# One of: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
